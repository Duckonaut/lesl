struct VsIn {
    float4 position,
    float4 color
}

struct FsOut {
    float4 color
}

struct ShaderLink {
    float4 color,
}

struct Uniforms {
    float4x4 projection,
}

function vertex (VsIn v, Uniforms u) -> (ShaderLink o) {
    o.color = v.color
    POSITION = u.projection * v.position
}

function fragment (ShaderLink i) -> (FsOut o) {
    o.color = i.color
}

pipeline Basic {
    Vertex = vertex,
    Fragment = fragment,
}
