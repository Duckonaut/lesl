struct VsIn {
    float4 position,
    float4 color
}

struct FsOut {
    float4 color
}

struct ShaderLink {
    float4 color,
}

function vertex (VsIn v) -> (ShaderLink o) {
    o.color = v.color
    POSITION = v.position
}

function manual_multiply (float4 a, float b) -> (float4 o) {
    o = a * b
}

function fragment (ShaderLink i) -> (FsOut o) {
    o.color = manual_multiply(i.color, 0.5)
}

pipeline Basic {
    Vertex = vertex,
    Fragment = fragment,
}
