struct VsIn {
    vec4 position,
    vec4 color
}

struct FsOut {
    vec4 color
}

struct Uniforms {
    vec4 color
}

struct ShaderLink {
    vec4 color,
}

function vertex (VsIn v) -> (ShaderLink o) {
    o.color = v.color
    POSITION = v.position
    gay.men(5 + 11 * 4)
}

function fragment (ShaderLink i, Uniforms u) -> (FsOut o) {
    o.color = i.color * u.color
}

pipeline Basic {
    Vertex = vertex,
    Fragment = fragment,
}
